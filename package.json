{
  "name": "rawtrace-mcp",
  "version": "0.1.0",
  "description": "A Playwright-powered MCP server for raw DOM mutation and network event tracing.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/ss26367098/rawtrace-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ss26367098/rawtrace-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/ss26367098/rawtrace-mcp/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "rawtrace-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "lint": "eslint .",
    "test": "npm run build && vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "npm run build && vitest run tests/integration",
    "test:real-run": "npm run build && node tests/real-run/all-tools-real-run.mjs",
    "prepack": "npm run build"
  },
  "keywords": [
    "mcp",
    "playwright",
    "cdp",
    "browser-automation",
    "trace",
    "dom",
    "network"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.28.0",
    "commander": "^14.0.2",
    "playwright": "^1.60.0",
    "yazl": "^3.3.1",
    "zod": "^4.1.13",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.1",
    "@emnapi/runtime": "^1.11.1",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/ws": "^8.18.1",
    "@types/yazl": "^2.4.5",
    "eslint": "^9.39.1",
    "ts-api-utils": "2.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0",
    "vitest": "^4.0.14",
    "ws": "^8.18.3"
  },
  "overrides": {
    "ts-api-utils": "2.1.0"
  }
}
